PULUMI_ACCESS_TOKEN=
PULUMI_STACK=prod

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1

ANTHROPIC_API_KEY=

# Table name — fixed, no need to change:
DYNAMODB_TABLE=reeds-articles

# YouTube integration (only needed if youtubers are configured in config.yaml)
# YOUTUBE_API_KEY — YouTube Data API v3 key (enables the YouTube source in the crawler Lambda)
#   Get it: console.cloud.google.com → APIs & Services → Credentials
# YOUTUBE_API_KEY=

# Optional: set to skip Pulumi lookup when running make digest locally
# Get value from: make infra-outputs
# CF_DISTRIBUTION_ID=
